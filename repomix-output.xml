                          <p style={{ fontWeight: 700, color: "#1e293b", fontSize: 13 }}>{pr.name}</p>
                          {pr.role && <p style={{ color: "#2563eb", fontSize: 12, fontWeight: 500 }}>{pr.role}</p>}
                        </div>
                        {pr.link && (
