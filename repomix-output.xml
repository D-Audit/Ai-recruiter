        <div class="order-form" id="orderForm">
          <div class="of-row">
            <div class="of-group">
              <label>First Name <span class="req">*</span></label>
              <input type="text" id="of-fname" placeholder="e.g. Jean Paul"/>
            </div>
            <div class="of-group">
              <label>Last Name <span class="req">*</span></label>
              <input type="text" id="of-lname" placeholder="e.g. Mugisha"/>
