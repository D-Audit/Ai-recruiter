        .dropdown-divider { height: 1px; background: rgba(255,255,255,0.07); margin: 2px 0; }

        /* Workflow banner */
        .workflow-banner {
          display: flex; align-items: center; gap: 10px;
          padding: 9px 28px; font-size: 13px; font-weight: 500;
