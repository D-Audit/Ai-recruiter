        .notif-item-time   { font-size: 10.5px; color: rgba(255,255,255,0.28); margin-top: 4px; }
        .notif-dot { width: 7px; height: 7px; border-radius: 50%; background: #3b82f6; flex-shrink: 0; margin-top: 5px; }

        /* Profile button */
