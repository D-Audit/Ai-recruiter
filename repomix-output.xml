        .sr-cache-badge { display: inline-flex; align-items: center; gap: 5px; padding: 4px 10px; border-radius: 99px; background: rgba(217,119,6,0.08); color: var(--text-secondary); font-size: 11px; font-weight: 700; }
        .sr-run-btn {
