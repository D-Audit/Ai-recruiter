          <div class="of-group">
            <label>Phone Number <span class="req">*</span></label>
            <input type="tel" id="of-phone" placeholder="+250 7XX XXX XXX"/>
          </div>
          <div class="of-group">
            <label>WhatsApp Number <span class="req">*</span></label>
            <input type="tel" id="of-whatsapp" placeholder="Same as phone or different WhatsApp number"/>
          </div>
          <div class="of-group">
            <label>Country <span class="req">*</span></label>
            <select id="of-country">
              <option value="">— Select your country —</option>
              <option value="Rwanda">🇷🇼 Rwanda</option>
              <option value="Uganda">🇺🇬 Uganda</option>
              <option value="Other">🌍 Other (East Africa)</option>
            </select>
          </div>
          <div class="of-group">
            <label>Delivery Address <span class="req">*</span></label>
            <input type="text" id="of-address" placeholder="e.g. Kimironko, Kigali / Kampala Road, Entebbe"/>
          </div>
          <div class="of-row">
            <div class="of-group">
              <label>Product <span class="req">*</span></label>
              <input type="text" id="of-product" readonly/>
            </div>
            <div class="of-group">
              <label>Quantity <span class="req">*</span></label>
              <div class="qty-wrap">
                <button type="button" class="qty-btn" id="qtyMinus">−</button>
                <input type="number" id="of-qty" value="1" min="1" max="99"/>
                <button type="button" class="qty-btn" id="qtyPlus">+</button>
              </div>
            </div>
          </div>
          <div class="of-group">
            <label>Additional Products / Special Request</label>
            <textarea id="of-extra" placeholder="Don't see what you need? Describe any other product you want here — we'll do our best to source it for you!"></textarea>
          </div>
          <button class="btn-order-submit" id="orderSubmit">
            <span class="btn-order-icon">📲</span>
            <span>Send Order via WhatsApp</span>
            <span class="btn-order-arrow">→</span>
          </button>
          <p class="order-note">WhatsApp will open with your order already written. Just tap <strong>Send</strong> and we'll confirm your delivery.</p>
