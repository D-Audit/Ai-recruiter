              </p>
            </div>

            {/* Stats */}
            <div className="dash-stats">
              {[
                {
                  label: "Total Jobs",
                  value: loading ? "—" : jobs.length,
                  icon: Briefcase,
                  iconBg: "rgba(37,99,235,0.08)",
