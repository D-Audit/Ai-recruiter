            <div className="dash-two-col">
              {/* Recent Jobs */}
              <div>
                <div className="dash-card">
                  <div className="dash-card-header">
                    <span className="dash-section-title" style={{ margin: 0 }}>
                      <Briefcase size={16} color="var(--brand-primary)" /> Recent Jobs
