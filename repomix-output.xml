        <div class="order-success" id="orderSuccess" style="display:none">
          <div class="success-icon">🎉</div>
          <h3>Order Sent!</h3>
          <p>Your order has been sent via WhatsApp. We will confirm your delivery shortly.</p>
          <p class="success-sub">Thank you for choosing Tip Top Consultancy!</p>
          <button class="btn-success-close" id="successClose">Close</button>
        </div>
