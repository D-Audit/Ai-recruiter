                      Run screening to see ranked candidates here, or open the{" "}
                      <Link href={`/screenings/${jobId}`} style={{ color: "#2563eb", fontWeight: 600 }}>
                        full results page
                      </Link>
                      .
                    </p>
                  )}
                </div>

                <div className="chat-card">
