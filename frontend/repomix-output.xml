                style={{
                  flex: 1,
                  padding: 12,
                  borderRadius: 11,
                  border: "1px solid #e2e8f0",
                  background: "white",
                  cursor: "pointer",
                  fontWeight: 600,
                }}
              >
                Cancel
              </button>
              <button
                type="button"
                disabled={deleting}
                onClick={handleDelete}
                style={{
                  flex: 1,
                  padding: 12,
                  borderRadius: 11,
                  border: "none",
                  background: "#dc2626",
                  color: "white",
                  fontWeight: 700,
                  cursor: "pointer",
