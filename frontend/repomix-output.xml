          {label}
        </p>
      )}
      <style>{`@keyframes spin { to { transform: rotate(360deg); } }`}</style>
    </div>
  );

  if (fullPage) {
    return (
      <div
        style={{
          position: "fixed",
          inset: 0,
          display: "flex",
          alignItems: "center",
          justifyContent: "center",
          background: "rgba(var(--surface-base-rgb, 241,245,249), 0.85)",
          zIndex: 999,
        }}
      >
        {inner}
      </div>
    );
  }

  return inner;
}
