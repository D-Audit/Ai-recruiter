              <div style={{ display: "flex", alignItems: "flex-start", gap: 12, background: "rgba(220,38,38,0.07)", border: "1.5px solid rgba(220,38,38,0.2)", borderRadius: 13, padding: "16px 18px", color: "#dc2626", fontSize: 14 }}>
