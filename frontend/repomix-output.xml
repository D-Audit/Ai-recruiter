            <Link href="/profile" className="st-profile-link">
              <User size={14} />
              Edit profile & display name
            </Link>

            {/* Password */}
            <div className="st-card">
              <p className="st-card-title">
                <KeyRound size={17} color="#2563eb" />
                Change Password
              </p>
              <p className="st-card-sub">
                Use a strong, unique password for your workspace. You'll need your current password to update it.
              </p>

              <div className="st-field">
                <label className="st-label">Current password</label>
                <div className="st-input-wrap">
                  <input
                    className="st-input"
                    type={showPwd.current ? "text" : "password"}
                    autoComplete="current-password"
                    placeholder="Enter current password"
                    value={pwd.currentPassword}
                    onChange={(e) => setPwd({ ...pwd, currentPassword: e.target.value })}
                  />
                  <button className="st-eye-btn" type="button" onClick={() => setShowPwd((s) => ({ ...s, current: !s.current }))}>
                    {showPwd.current ? <EyeOff size={15} /> : <Eye size={15} />}
                  </button>
                </div>
              </div>

              <div className="st-field">
                <label className="st-label">New password</label>
                <div className="st-input-wrap">
                  <input
                    className="st-input"
                    type={showPwd.new ? "text" : "password"}
                    autoComplete="new-password"
                    placeholder="Min. 6 characters"
                    value={pwd.newPassword}
                    onChange={(e) => setPwd({ ...pwd, newPassword: e.target.value })}
                  />
                  <button className="st-eye-btn" type="button" onClick={() => setShowPwd((s) => ({ ...s, new: !s.new }))}>
                    {showPwd.new ? <EyeOff size={15} /> : <Eye size={15} />}
                  </button>
                </div>
                {strength && (
                  <>
                    <div className="st-strength-track">
                      <div className="st-strength-fill" style={{ width: strength.w, background: strength.bg }} />
                    </div>
                    <p className="st-strength-label" style={{ color: strength.color }}>{strength.label}</p>
                  </>
                )}
              </div>

              <div className="st-field">
                <label className="st-label">Confirm new password</label>
                <div className="st-input-wrap">
                  <input
                    className="st-input"
                    type={showPwd.confirm ? "text" : "password"}
                    autoComplete="new-password"
                    placeholder="Repeat new password"
                    value={pwd.confirmPassword}
                    onChange={(e) => setPwd({ ...pwd, confirmPassword: e.target.value })}
                  />
                  <button className="st-eye-btn" type="button" onClick={() => setShowPwd((s) => ({ ...s, confirm: !s.confirm }))}>
                    {showPwd.confirm ? <EyeOff size={15} /> : <Eye size={15} />}
                  </button>
                </div>
                {pwd.confirmPassword && pwd.newPassword !== pwd.confirmPassword && (
                  <p style={{ fontSize: 12, color: "#dc2626", marginTop: 5, fontWeight: 500 }}>Passwords don't match</p>
                )}
                {pwd.confirmPassword && pwd.newPassword === pwd.confirmPassword && pwd.confirmPassword.length >= 6 && (
                  <p style={{ fontSize: 12, color: "#15803d", marginTop: 5, fontWeight: 500, display: "flex", alignItems: "center", gap: 4 }}>
                    <CheckCircle2 size={13} /> Passwords match
                  </p>
                )}
              </div>

              <button
                type="button"
                className={`st-btn${pwdSaved ? " saved" : ""}`}
                disabled={pwdSaving || !pwd.currentPassword || !pwd.newPassword}
                onClick={handleChangePassword}
              >
                {pwdSaved ? <CheckCircle2 size={15} /> : <Shield size={15} />}
                {pwdSaving ? "Updating…" : pwdSaved ? "Updated!" : "Update Password"}
              </button>
            </div>

            {/* Preferences */}
            <div className="st-card">
              <p className="st-card-title">
                <Bell size={17} color="#7c3aed" />
                Preferences
              </p>
              <p className="st-card-sub">
                Notification toggles are stored locally on this device.
              </p>
              <div className="st-row">
                <div>
                  <p style={{ fontWeight: 600, fontSize: 14, color: "var(--text-primary)" }}>Screening completed</p>
                  <p style={{ fontSize: 12.5, color: "var(--text-muted)", marginTop: 3 }}>
                    Show a notification when an AI screening run finishes
                  </p>
                </div>
                <button
                  type="button"
                  className={`st-toggle${notifyScreening ? " on" : ""}`}
                  aria-pressed={notifyScreening}
                  aria-label="Toggle screening notifications"
                  onClick={() => setNotifyScreening(!notifyScreening)}
                />
              </div>
            </div>

            {/* Workspace */}
            <div className="st-card">
              <p className="st-card-title">
                <Database size={17} color="#64748b" />
                Workspace &amp; Data
              </p>
              <p className="st-card-sub">
                Umurava AI Recruiter — screening data is scoped per job. Uploaded candidates are attached only to the job you select.
              </p>
              <div className="st-meta">
                {[
                  ["Screening cache", "24h semantic"],
                  ["Compare", "Up to 3 candidates"],
                  ["AI model", "Gemini"],
                  ["Exports", "PDF / CSV"],
                ].map(([k, v]) => (
                  <div key={k} className="st-meta-cell">
                    <p className="st-meta-k">{k}</p>
                    <p className="st-meta-v">{v}</p>
                  </div>
                ))}
              </div>
              <div className="st-divider" style={{ marginTop: 18 }} />
              <div className="st-info-row">
                <Database size={16} style={{ flexShrink: 0, marginTop: 2, color: "var(--text-muted)" }} />
                <p>
                  Candidate uploads (CSV, PDF, manual) are always tied to the job chosen on the Applicants page.
                  Open a job and use "Add Applicants" to pre-select that role.
                </p>
              </div>
              <div className="st-info-row">
                <FileText size={16} style={{ flexShrink: 0, marginTop: 2, color: "var(--text-muted)" }} />
                <p>
                  Use screening results to compare two or three candidates side-by-side — the AI assistant automatically uses your latest screening when you ask about shortlists.
                </p>
              </div>
            </div>

          </div>
        </div>
      </div>
    </>
  );
}
</file>

