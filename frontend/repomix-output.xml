        .skel { border-radius: 6px; background: linear-gradient(90deg, #f1f5f9 25%, #e8edf3 50%, #f1f5f9 75%); background-size: 200% 100%; animation: shimmer 1.5s infinite; }

        @media (max-width: 1200px) {
