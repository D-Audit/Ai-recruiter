                                  {fp.status === "error" ? "Failed" : fp.status === "done" ? "Done ✓" : `${fp.pct}%`}
                                </span>
                              </div>
                              <div style={{ height: "6px", background: "#e2e8f0", borderRadius: "99px", overflow: "hidden" }}>
