        }
        .sb-user:hover { background: rgba(255,255,255,0.06); }
        .sb-avatar {
          width: 36px; height: 36px; border-radius: 50%; flex-shrink: 0;
          background: linear-gradient(135deg, #1e3a5f, #2d1b6e);
