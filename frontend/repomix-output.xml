}

.empty-title {
  font-size: 18px;
  font-weight: 700;
  color: var(--text-primary);
}

.empty-desc {
  font-size: 14px;
  color: var(--text-secondary);
  max-width: 360px;
  line-height: 1.6;
}

/* ─── Toast Overrides ────────────────────────────────────────── */
.go2072408551 {
  font-family: var(--font-body) !important;
  font-size: 14px !important;
  font-weight: 500 !important;
  border-radius: 12px !important;
}
