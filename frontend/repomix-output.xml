        .auth-pwd-toggle {
          position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
          background: none; border: none; cursor: pointer; color: #94a3b8; padding: 4px 5px; border-radius: 6px;
          transition: color 0.15s;
