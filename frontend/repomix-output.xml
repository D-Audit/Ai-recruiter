                >
                  Clear filters
                </button>
              </div>
            ) : (
              <div className="jp-grid">
                {filtered.map((job) => {
                  const s = statusConfig[job.status] ?? statusConfig.closed;
                  return (
                    <div
                      key={job._id}
                      className="jp-card"
                      onClick={() => router.push(`/jobs/${job._id}`)}
