        {/* Nav */}
        <p className="sb-section-label">Navigation</p>
        <nav className="sb-nav">
          {navItems.map((item) => {
            const active =
              pathname === item.href ||
              (item.href !== "/dashboard" && pathname.startsWith(item.href + "/"));
            return (
              <Link key={item.href} href={item.href} className={`sb-link ${active ? "active" : ""}`}>
                <span className="sb-icon">
                  <item.icon size={17} />
