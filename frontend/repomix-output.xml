          borderRadius: "50%",
          animation: "spin 0.75s linear infinite",
        }}
      />
      {label && (
        <p
          style={{
            color: "var(--text-muted, #64748b)",
            fontSize: 14,
            fontWeight: 500,
            fontFamily: "var(--font-body, system-ui)",
          }}
